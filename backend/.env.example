PORT=5000

# ── Database (local dev) ─────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=productivity_db

# Alternatively, a single connection string (Render/Supabase/etc.)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Firebase Admin (required after Firebase Auth migration) ──
# Option A: Service-account JSON path (recommended locally)
#   1. Firebase Console → Project settings → Service accounts
#   2. "Generate new private key" → download the JSON
#   3. Save it outside git (e.g. backend/secrets/firebase-admin.json)
#   4. Point this variable at the absolute path
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-admin.json
#
# Option B: Inline JSON (for Render / serverless)
#   Paste the entire service-account JSON as a single line.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
FIREBASE_PROJECT_ID=productivity-saas

# ── Frontend URL (CORS) ──────────────────────────────────────
# Comma-separated list is allowed in FRONTEND_URLS for multi-env deployments.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=http://localhost:5173,https://your-app.vercel.app

# ── Email (Resend) ───────────────────────────────────────────
# Get a key at https://resend.com. Leave empty to disable email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ── Legacy JWT secret (kept only for existing issued tokens) ─
# Safe to remove once all clients use Firebase ID tokens.
JWT_SECRET=generate-a-long-random-string-here
